# Copy to .env.local for local dev, and add these as GitHub Actions secrets/variables for deploy.
# Both values are safe to expose publicly (the anon key is designed for browser use).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Formspree form ID for the contact form (from your Formspree dashboard)
VITE_FORMSPREE_ID=your-form-id
